<windows:PersistentCraftStationWindow
    xmlns="https://spacestation14.io"
    xmlns:windows="clr-namespace:Content.Client._Stalker.PersistentCrafting.UI"
    Title="{Loc 'persistent-craft-menu-title'}"
    MinWidth="980"
    MinHeight="680">
    <BoxContainer Orientation="Vertical" Margin="8 8 8 8">
        <BoxContainer Orientation="Horizontal" Margin="0 0 0 6">
            <Label Name="PointsLabel" Access="Public" HorizontalExpand="True" />
            <Button Name="OpenSkillsButton" Access="Public" Text="{Loc 'persistent-craft-station-open-skills'}" />
        </BoxContainer>
        <RichTextLabel Name="SummaryLabel" Access="Public" Margin="0 0 0 8" />
        <TabContainer Name="Branches" Access="Public" VerticalExpand="True">
            <BoxContainer Name="WeaponBranch" Access="Public" Orientation="Vertical" Margin="8 8 8 8" HorizontalExpand="True" VerticalExpand="True" />
            <BoxContainer Name="ArmorBranch" Access="Public" Orientation="Vertical" Margin="8 8 8 8" HorizontalExpand="True" VerticalExpand="True" />
            <BoxContainer Name="AnomalyBranch" Access="Public" Orientation="Vertical" Margin="8 8 8 8" HorizontalExpand="True" VerticalExpand="True" />
        </TabContainer>
    </BoxContainer>
</windows:PersistentCraftStationWindow>
